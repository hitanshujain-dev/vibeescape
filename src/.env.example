# ─── Backend API ────────────────────────────────────────────────
# Set this to your Render backend URL after deploying
# Example: https://vibeescape-backend.onrender.com/api/places
VITE_API_URL=https://YOUR-BACKEND.onrender.com/api/places

# ─── Optional: Third-party keys (not required for core functionality) ──
# These were used for image-fetching scripts only — not needed in production
# VITE_UNSPLASH_ACCESS_KEY=
# VITE_GOOGLE_API_KEY=
# VITE_GOOGLE_CX=
# VITE_PEXELS_API_KEY=
